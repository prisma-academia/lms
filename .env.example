# Copy to `.env` and adjust values for your environment.
# Required variables are validated at startup via `lib/env.ts`.

# --- Core ---
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multi_tenant
APP_DOMAIN=localhost:3000
PLATFORM_SUBDOMAIN=platform
PRODUCT_NAME=Prisma LMS
TENANT_TRIAL_DAYS=90
# Dev URLs:
#   Marketing:  http://localhost:3000
#   Platform:   http://platform.localhost:3000
#   Tenant:     http://{slug}.localhost:3000

# --- Auth & security ---
# SESSION_SECRET: min 16 characters
SESSION_SECRET=change-me-to-a-long-random-string
# OTP_PEPPER: min 8 characters (peppers email OTP hashes)
OTP_PEPPER=change-me-otp-pepper

# --- Platform seed user (used by `npm run db:seed`) ---
PLATFORM_ADMIN_EMAIL=admin@example.com
# PLATFORM_ADMIN_PASSWORD: min 12 characters
PLATFORM_ADMIN_PASSWORD=change-me-12ch

# --- SMTP (transactional email) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=Prisma LMS
# Set to "true" for TLS (e.g. port 465)
SMTP_SECURE=false

# --- Billing (Paystack + Flutterwave) — optional ---
# Platform keys only; tenants never provide payment API keys.
# PLATFORM_COMMISSION_PCT=10
# PAYSTACK_SECRET_KEY=
# PAYSTACK_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=
# FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_HASH=

# --- Rate limiting (Upstash Redis) — optional ---
# When unset, rate limiting is skipped (fails open).
# RATE_LIMIT_ENABLED=false
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Object storage (S3 / MinIO) — optional ---
# Branding uploads are disabled until bucket + credentials are set.
# S3_REGION=us-east-1
# S3_BUCKET=tenant-assets
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_BASE_URL=http://localhost:9000/tenant-assets
# S3_FORCE_PATH_STYLE=true

# --- i18n ---
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,es
