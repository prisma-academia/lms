generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ClientStatus {
  ACTIVE
  SUSPENDED
}

enum RoleScope {
  PLATFORM
  TENANT
}

enum ActorType {
  PLATFORM_USER
  TENANT_USER
  CLIENT
  SYSTEM
}

enum SessionUserType {
  PLATFORM
  TENANT
  CLIENT
}

enum SessionScope {
  FULL
  MUST_CHANGE_PASSWORD
}

enum OtpPurpose {
  CLIENT_LOGIN
  CLIENT_SIGNUP
  TENANT_REGISTRATION
  TENANT_OWNER_CHANGE_EMAIL
}

enum TenantPlan {
  TRIAL
  ACTIVE
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum SubaccountStatus {
  PENDING
  ACTIVE
  FAILED
  SUSPENDED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Access visibility for courses and programmes.
/// PUBLIC: appears in the client catalog and is self-enrollable.
/// PRIVATE: hidden from catalog; learners must be manually onboarded by staff.
enum ContentVisibility {
  PUBLIC
  PRIVATE
}

enum LessonContentType {
  TEXT
  VIDEO_URL
  FILE
  QUIZ
}

enum AssignmentType {
  TEXT
  FILE
  LINK
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
  RETURNED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
}

enum EventType {
  LIVE_SESSION
  DEADLINE
  REMINDER
  ANNOUNCEMENT
}

enum EventAudience {
  ALL
  CLIENT
  GROUP
}

enum EventRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum NotificationCategory {
  MESSAGE
  ANNOUNCEMENT
  REMINDER
}

model Tenant {
  id                   String             @id @default(cuid())
  slug                 String             @unique
  name                 String
  status               TenantStatus       @default(ACTIVE)
  plan                 TenantPlan         @default(TRIAL)
  trialEndsAt          DateTime?
  storageUsedBytes     BigInt             @default(0)
  storageQuotaBytes    BigInt             @default(10737418240)
  subscriptionStatus   SubscriptionStatus @default(NONE)
  subscriptionPlanId   String?
  subscriptionPlan     SubscriptionPlan?  @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  subscriptionEndsAt   DateTime?
  billingProvider      PaymentProvider?
  billingCustomerRef   String?
  ownerUserId          String?
  companyEmail         String?
  companyPhone         String?
  website              String?
  addressLine1         String?
  addressLine2         String?
  city                 String?
  region               String?
  postalCode           String?
  country              String?
  settingsJson         Json               @default("{}")
  createdAt            DateTime           @default(now())
  archivedAt           DateTime?

  users                        TenantUser[]
  clients                      Client[]
  userGroups                   UserGroup[]
  clientGroups                 ClientGroup[]
  pendingClientRegistrations   PendingClientRegistration[]
  roleTemplates                RoleTemplate[]
  templates                    Template[]
  activityLogs                 ActivityLog[]
  subaccount                   TenantSubaccount?
  courses                      Course[]
  programmes                   Programme[]
  platformPayments             PlatformPayment[]
  coursePayments               CoursePayment[]
  programmePayments            ProgrammePayment[]
  assignments                  Assignment[]
  submissions                  Submission[]
  grades                       Grade[]
  fees                         Fee[]
  questionBanks                QuestionBank[]
  questionTags                 QuestionTag[]
  quizzes                      Quiz[]
  certificates                 Certificate[]
  events                       Event[]
  messages                     Message[]
  libraryItems                 LibraryItem[]
  libraryFolders               LibraryFolder[]
  libraryTags                  LibraryTag[]

  @@index([status])
  @@index([plan, trialEndsAt])
  @@index([subscriptionStatus])
}

model SubscriptionPlan {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  priceMonthlyCents Int
  currency          String   @default("NGN")
  storageQuotaBytes BigInt
  maxLearners       Int?
  maxInstructors    Int?
  maxCourses        Int?
  isPublic          Boolean  @default(true)
  sortOrder         Int      @default(0)
  tenants           Tenant[]
}

model TenantSubaccount {
  tenantId                String           @id
  tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessName            String
  businessEmail           String?
  businessPhone           String?
  settlementBankCode      String
  settlementAccountNumber String
  settlementAccountName   String?
  paystackSubaccountCode  String?
  paystackStatus          SubaccountStatus @default(PENDING)
  paystackProvisionedAt   DateTime?
  flutterwaveSubaccountId String?
  flutterwaveStatus       SubaccountStatus @default(PENDING)
  flutterwaveProvisionedAt DateTime?
  courseSalesEnabled      Boolean          @default(false)
  platformCommissionPct   Int              @default(10)
  defaultProvider         PaymentProvider?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
}

model PlatformPayment {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId       String
  provider     PaymentProvider
  amountCents  Int
  currency     String
  status       PaymentStatus   @default(PENDING)
  externalRef  String          @unique
  providerData Json?
  createdAt    DateTime        @default(now())
  completedAt  DateTime?

  @@index([tenantId, createdAt])
}

/// A Client pays a Tenant for a whole Programme (course bundle); supports split
/// payout. On success every published course in the programme is enrolled.
model ProgrammePayment {
  id                String          @id @default(cuid())
  tenantId          String
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  programmeId       String
  programme         Programme       @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  clientId          String
  client            Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider          PaymentProvider
  amountCents       Int
  currency          String
  status            PaymentStatus   @default(PENDING)
  externalRef       String          @unique
  platformFeeCents  Int?
  tenantPayoutCents Int?
  providerData      Json?
  createdAt         DateTime        @default(now())
  completedAt       DateTime?

  @@index([tenantId, createdAt])
  @@index([programmeId])
  @@index([clientId])
}

model Course {
  id           String       @id @default(cuid())
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String
  slug         String
  description  String?
  status       CourseStatus @default(DRAFT)
  visibility   ContentVisibility @default(PUBLIC)
  priceCents   Int?
  currency     String       @default("NGN")
  thumbnailKey String?
  instructorId String?
  publishedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  lessons      Lesson[]
  lessonGroups LessonGroup[]
  enrollments  Enrollment[]
  payments     CoursePayment[]
  assignments  Assignment[]
  programmes   ProgrammeCourse[]
  certificates Certificate[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

model Lesson {
  id          String            @id @default(cuid())
  courseId    String
  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenantId    String
  groupId     String?
  group       LessonGroup?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  title       String
  sortOrder   Int               @default(0)
  contentType LessonContentType @default(TEXT)
  contentJson Json              @default("{}")
  assetKey    String?
  durationMin Int?
  createdAt   DateTime          @default(now())
  progress    LessonProgress[]

  @@index([courseId, sortOrder])
  @@index([tenantId])
  @@index([groupId])
}

/// A group/subgroup within a course to organize lessons beyond flat sortOrder.
/// Self-referencing via parentId for subgroups.
model LessonGroup {
  id        String        @id @default(cuid())
  tenantId  String
  courseId  String
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    LessonGroup?  @relation("LessonGroupTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  LessonGroup[] @relation("LessonGroupTree")
  title     String
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  lessons   Lesson[]

  @@index([tenantId])
  @@index([courseId, sortOrder])
  @@index([parentId])
}

/// A programme groups multiple courses into a curriculum. Courses can be
/// standalone or belong to one or more programmes (via ProgrammeCourse).
model Programme {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String
  slug         String
  description  String?
  status       CourseStatus      @default(DRAFT)
  visibility   ContentVisibility @default(PUBLIC)
  priceCents   Int?
  currency     String            @default("NGN")
  thumbnailKey String?
  publishedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  courses      ProgrammeCourse[]
  certificates Certificate[]
  payments     ProgrammePayment[]

  @@unique([tenantId, slug])
  @@index([tenantId, status])
}

/// Join row: a Course within a Programme. Marks required/optional, ordering,
/// and an optional group/subgroup label for organizing courses in a programme.
model ProgrammeCourse {
  id          String    @id @default(cuid())
  tenantId    String
  programmeId String
  programme   Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  required    Boolean   @default(true)
  sortOrder   Int       @default(0)
  groupLabel  String?
  createdAt   DateTime  @default(now())

  @@unique([programmeId, courseId])
  @@index([tenantId])
  @@index([courseId])
}

model Enrollment {
  id              String           @id @default(cuid())
  tenantId        String
  courseId        String
  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enrolledAt      DateTime         @default(now())
  completedAt     DateTime?
  progressPercent Int              @default(0)
  paymentId       String?          @unique
  payment         CoursePayment?   @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  lessonProgress  LessonProgress[]

  @@unique([courseId, clientId])
  @@index([tenantId])
  @@index([clientId])
}

model LessonProgress {
  id           String     @id @default(cuid())
  tenantId     String
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now())

  @@unique([enrollmentId, lessonId])
  @@index([tenantId])
}

model CoursePayment {
  id               String          @id @default(cuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId         String
  course           Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  clientId         String
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  provider         PaymentProvider
  amountCents      Int
  currency         String
  status           PaymentStatus   @default(PENDING)
  externalRef      String          @unique
  platformFeeCents Int?
  tenantPayoutCents Int?
  providerData     Json?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?
  enrollment       Enrollment?

  @@index([tenantId, createdAt])
}

model Assignment {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        AssignmentType @default(TEXT)
  maxPoints   Int            @default(100)
  dueAt       DateTime?
  publishedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  submissions Submission[]

  @@index([tenantId, courseId])
  @@index([tenantId, dueAt])
}

model Submission {
  id           String           @id @default(cuid())
  tenantId     String
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status       SubmissionStatus @default(SUBMITTED)
  textBody     String?
  fileKey      String?
  linkUrl      String?
  submittedAt  DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  grade        Grade?

  @@unique([assignmentId, clientId])
  @@index([tenantId, assignmentId])
  @@index([tenantId, clientId])
}

model Grade {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  courseId     String
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  points       Int
  maxPoints    Int
  feedback     String?
  gradedById   String?
  gradedAt     DateTime   @default(now())

  @@index([tenantId, clientId])
  @@index([tenantId, courseId])
}

/// A fee a tenant charges its clients. Targets either a single client or a
/// whole client group (exactly one of clientId / clientGroupId is set).
model Fee {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  amountCents   Int
  currency      String       @default("NGN")
  dueAt         DateTime?
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientGroupId String?
  clientGroup   ClientGroup? @relation(fields: [clientGroupId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  payments      FeePayment[]

  @@index([tenantId])
  @@index([clientId])
  @@index([clientGroupId])
}

/// A payment recorded against a fee, per client. Lets staff track who has paid.
model FeePayment {
  id          String        @id @default(cuid())
  tenantId    String
  feeId       String
  fee         Fee           @relation(fields: [feeId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amountCents Int
  currency    String        @default("NGN")
  status      PaymentStatus @default(SUCCESS)
  method      String?
  paidAt      DateTime?
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([feeId, clientId])
  @@index([tenantId])
  @@index([feeId])
  @@index([clientId])
}

/// A collection of questions. Access can be scoped to specific user groups via
/// QuestionBankAccess; no rows = accessible to all staff with the quizzes perm.
model QuestionBank {
  id           String               @id @default(cuid())
  tenantId     String
  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  questions    Question[]
  accessGroups QuestionBankAccess[]

  @@index([tenantId])
}

/// Restricts a question bank to a user group. Presence of any row = restricted.
model QuestionBankAccess {
  id          String       @id @default(cuid())
  tenantId    String
  bankId      String
  bank        QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  userGroupId String
  userGroup   UserGroup    @relation(fields: [userGroupId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@unique([bankId, userGroupId])
  @@index([tenantId])
}

model QuestionTag {
  id       String            @id @default(cuid())
  tenantId String
  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  links    QuestionTagLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Question {
  id          String            @id @default(cuid())
  tenantId    String
  bankId      String
  bank        QuestionBank      @relation(fields: [bankId], references: [id], onDelete: Cascade)
  type        QuestionType      @default(SINGLE_CHOICE)
  prompt      String
  optionsJson Json              @default("[]")
  answerJson  Json              @default("[]")
  points      Int               @default(1)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tags        QuestionTagLink[]
  quizLinks   QuizQuestion[]

  @@index([tenantId])
  @@index([bankId])
}

model QuestionTagLink {
  id         String      @id @default(cuid())
  tenantId   String
  questionId String
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tagId      String
  tag        QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([questionId, tagId])
  @@index([tenantId])
}

model Quiz {
  id           String         @id @default(cuid())
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  passingScore Int?
  timeLimitMin Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  questions    QuizQuestion[]
  attempts     QuizAttempt[]

  @@index([tenantId])
}

model QuizQuestion {
  id         String   @id @default(cuid())
  tenantId   String
  quizId     String
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  points     Int?

  @@unique([quizId, questionId])
  @@index([tenantId])
  @@index([quizId, sortOrder])
}

model QuizAttempt {
  id           String    @id @default(cuid())
  tenantId     String
  quizId       String
  quiz         Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startedAt    DateTime  @default(now())
  submittedAt  DateTime?
  scorePercent Int?
  passed       Boolean?
  answersJson  Json      @default("{}")

  @@index([tenantId])
  @@index([quizId])
  @@index([clientId])
}

/// A certificate template (design stored as contentJson for the WYSIWYG editor),
/// optionally tied to a specific course or programme it certifies completion of.
model Certificate {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  courseId    String?
  course      Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  programmeId String?
  programme   Programme?         @relation(fields: [programmeId], references: [id], onDelete: SetNull)
  contentJson Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  awards      CertificateAward[]

  @@index([tenantId])
}

/// An issued certificate for a client, tied to a course/programme completion.
model CertificateAward {
  id            String      @id @default(cuid())
  tenantId      String
  certificateId String
  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  courseId      String?
  programmeId   String?
  serial        String      @unique
  issuedAt      DateTime    @default(now())

  @@unique([certificateId, clientId])
  @@index([tenantId])
  @@index([clientId])
}

/// A scheduled tenant activity (session, deadline, reminder, announcement).
/// Targets all clients, a single client, or a client group; supports simple
/// recurrence.
model Event {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  type            EventType       @default(ANNOUNCEMENT)
  startAt         DateTime
  endAt           DateTime?
  location        String?
  url             String?
  audience        EventAudience   @default(ALL)
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientGroupId   String?
  clientGroup     ClientGroup?    @relation(fields: [clientGroupId], references: [id], onDelete: Cascade)
  recurrence      EventRecurrence @default(NONE)
  recurrenceUntil DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId, startAt])
}

/// A tenant-to-client message. Materialized to MessageRecipient rows on send.
model Message {
  id            String               @id @default(cuid())
  tenantId      String
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subject       String
  body          String
  category      NotificationCategory @default(MESSAGE)
  senderUserId  String?
  audience      EventAudience        @default(ALL)
  clientId      String?
  clientGroupId String?
  createdAt     DateTime             @default(now())
  recipients    MessageRecipient[]

  @@index([tenantId, createdAt])
}

/// Per-client delivery of a message, with read tracking (the client inbox).
model MessageRecipient {
  id        String    @id @default(cuid())
  tenantId  String
  messageId String
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@unique([messageId, clientId])
  @@index([tenantId])
  @@index([clientId, readAt])
}

/// A per-recipient in-app notification with read tracking (the bell).
model Notification {
  id        String               @id @default(cuid())
  tenantId  String
  clientId  String
  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category  NotificationCategory
  title     String
  body      String?
  readAt    DateTime?
  createdAt DateTime             @default(now())

  @@index([tenantId])
  @@index([clientId, readAt])
}

/// Per-client, per-category channel preferences (in-app / email).
model NotificationPreference {
  id       String               @id @default(cuid())
  tenantId String
  clientId String
  client   Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category NotificationCategory
  inApp    Boolean              @default(true)
  email    Boolean              @default(true)

  @@unique([clientId, category])
  @@index([tenantId])
}

/// A folder for organizing library items (self-referencing subtree).
model LibraryFolder {
  id        String          @id @default(cuid())
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  parentId  String?
  parent    LibraryFolder?  @relation("LibraryFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  LibraryFolder[] @relation("LibraryFolderTree")
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  items     LibraryItem[]

  @@index([tenantId])
  @@index([parentId])
}

/// A managed media file in the tenant library.
model LibraryItem {
  id          String            @id @default(cuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  key         String
  contentType String
  sizeBytes   BigInt            @default(0)
  folderId    String?
  folder      LibraryFolder?    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tags        LibraryItemTag[]

  // `key` is unique per tenant, not globally: a global unique lets one tenant's
  // insert fail on another tenant's key and leaks key existence across tenants.
  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([folderId])
}

model LibraryTag {
  id       String           @id @default(cuid())
  tenantId String
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name     String
  links    LibraryItemTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model LibraryItemTag {
  id       String      @id @default(cuid())
  tenantId String
  itemId   String
  item     LibraryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tagId    String
  tag      LibraryTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([itemId, tagId])
  @@index([tenantId])
}

model PlatformConfig {
  key       String   @id
  valueJson Json
  updatedAt DateTime @updatedAt
}

model PlatformUser {
  id                   String      @id @default(cuid())
  email                String      @unique
  passwordHash         String
  mustChangePassword   Boolean     @default(true)
  status               UserStatus  @default(ACTIVE)
  firstName            String?
  lastName             String?
  otherName            String?
  phone                String?
  isSuperAdmin         Boolean     @default(false)
  permissions          String[]    @default([])
  createdAt            DateTime    @default(now())
  lastLoginAt          DateTime?
  failedLoginAttempts  Int         @default(0)
  lockedUntil          DateTime?
}

model TenantUser {
  id                   String      @id @default(cuid())
  tenantId             String
  tenant               Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                String
  passwordHash         String
  mustChangePassword   Boolean     @default(true)
  status               UserStatus  @default(ACTIVE)
  firstName            String?
  lastName             String?
  otherName            String?
  phone                String?
  isOwner              Boolean     @default(false)
  permissions          String[]    @default([])
  createdAt            DateTime    @default(now())
  lastLoginAt          DateTime?
  failedLoginAttempts  Int         @default(0)
  lockedUntil          DateTime?
  groupMemberships     TenantUserGroupMembership[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Client {
  id                   String       @id @default(cuid())
  tenantId             String
  tenant               Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                String
  passwordHash         String?
  mustChangePassword   Boolean      @default(false)
  status               ClientStatus @default(ACTIVE)
  firstName            String?
  lastName             String?
  otherName            String?
  phone                String?
  profileJson          Json         @default("{}")
  createdAt            DateTime     @default(now())
  lastLoginAt          DateTime?
  failedLoginAttempts  Int          @default(0)
  lockedUntil          DateTime?
  enrollments          Enrollment[]
  coursePayments       CoursePayment[]
  programmePayments    ProgrammePayment[]
  submissions          Submission[]
  grades               Grade[]
  groupMemberships     ClientGroupMembership[]
  fees                 Fee[]
  feePayments          FeePayment[]
  quizAttempts         QuizAttempt[]
  certificateAwards    CertificateAward[]
  events               Event[]
  messageReceipts      MessageRecipient[]
  notifications        Notification[]
  notificationPrefs    NotificationPreference[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

/// A cohort/group of tenant staff users (many-to-many via TenantUserGroupMembership).
model UserGroup {
  id          String                       @id @default(cuid())
  tenantId    String
  tenant      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  memberships TenantUserGroupMembership[]
  bankAccess  QuestionBankAccess[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Join row: a TenantUser belongs to a UserGroup. Tenant-scoped for isolation.
model TenantUserGroupMembership {
  id        String     @id @default(cuid())
  tenantId  String
  groupId   String
  group     UserGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      TenantUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([groupId, userId])
  @@index([tenantId])
  @@index([userId])
}

/// A cohort/group of clients (learners), many-to-many via ClientGroupMembership.
model ClientGroup {
  id          String                   @id @default(cuid())
  tenantId    String
  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  memberships ClientGroupMembership[]
  fees        Fee[]
  events      Event[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Join row: a Client belongs to a ClientGroup. Tenant-scoped for isolation.
model ClientGroupMembership {
  id        String      @id @default(cuid())
  tenantId  String
  groupId   String
  group     ClientGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([groupId, clientId])
  @@index([tenantId])
  @@index([clientId])
}

model PasswordResetToken {
  id         String           @id @default(cuid())
  tokenHash  String           @unique
  userType   SessionUserType
  userId     String
  tenantId   String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([expiresAt])
}

/// In-flight client self-signup: created after form+password, deleted after OTP verifies.
model PendingClientRegistration {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  firstName    String?
  lastName     String?
  otherName    String?
  phone        String?
  profileJson  Json     @default("{}")
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
}

model RoleTemplate {
  id          String     @id @default(cuid())
  scope       RoleScope
  tenantId    String?
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  permissions String[]
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())

  @@unique([scope, tenantId, name])
  @@index([scope, tenantId])
}

model Permission {
  key         String  @id
  module      String
  description String
}

model ActivityLog {
  id         String     @id @default(cuid())
  tenantId   String?
  tenant     Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  actorType  ActorType
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  beforeJson Json?
  afterJson  Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime   @default(now())

  @@index([tenantId, createdAt])
  @@index([actorId])
  @@index([action])
}

model OtpRequest {
  id         String     @id @default(cuid())
  identifier String
  codeHash   String
  purpose    OtpPurpose
  tenantId   String?
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0)
  createdAt  DateTime   @default(now())

  @@index([identifier, createdAt])
  @@index([tenantId])
}

model Session {
  id          String           @id
  userId      String
  userType    SessionUserType
  tenantId    String?
  scope       SessionScope     @default(FULL)
  issuedAt    DateTime         @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  ip          String?
  userAgent   String?

  @@index([userId])
  @@index([expiresAt])
}

model Template {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String
  name        String
  contentJson Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([tenantId, type])
}

model PasswordHistory {
  id        String   @id @default(cuid())
  userType  SessionUserType
  userId    String
  hash      String
  createdAt DateTime @default(now())

  @@index([userType, userId, createdAt])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  identifier String
  scope      String
  success    Boolean
  ip         String?
  createdAt  DateTime @default(now())

  @@index([identifier, scope, createdAt])
}

model ReservedSlug {
  slug      String   @id
  reason    String
  createdAt DateTime @default(now())
}
