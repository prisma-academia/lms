{
  "name": "prisma-lms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma generate && node scripts/copy-pdf-worker.mjs && next build",
    "postinstall": "node scripts/copy-pdf-worker.mjs",
    "start": "next start",
    "mastra": "mastra dev",
    "mastra:build": "mastra build",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "db:seed:verify": "tsx scripts/verify-demo-seed.ts",
    "verify:library-access": "tsx scripts/verify-library-access.ts",
    "verify:library-matrix": "tsx scripts/verify-library-matrix.ts",
    "jobs:expire-trials": "tsx scripts/jobs.ts expire-trials",
    "jobs:trial-reminders": "tsx scripts/jobs.ts trial-reminders",
    "jobs:reconcile-storage": "tsx -e \"import { reconcileStorage } from './lib/jobs/reconcile-storage'; reconcileStorage().then(n => console.log('Updated', n)).catch(e => { console.error(e); process.exit(1); })\"",
    "jobs:prune-uploads": "tsx -e \"import { pruneUploadSessions } from './lib/jobs/reconcile-storage'; pruneUploadSessions().then(n => console.log('Pruned', n)).catch(e => { console.error(e); process.exit(1); })\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "@mastra/core": "^1.51.0",
    "@mastra/duckdb": "^1.5.1",
    "@mastra/libsql": "^1.16.0",
    "@mastra/loggers": "^1.2.0",
    "@mastra/memory": "^1.23.0",
    "@mastra/observability": "^1.16.1",
    "@mastra/pg": "^1.16.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "isomorphic-dompurify": "^3.19.0",
    "mastra": "^1.19.0",
    "next": "16.2.6",
    "next-intl": "^4.12.0",
    "nodemailer": "^8.0.7",
    "pdfjs-dist": "^6.1.200",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright-core": "^1.61.1",
    "prisma": "^7.8.0",
    "react-email": "^6.1.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.0",
    "typescript": "^5"
  }
}
